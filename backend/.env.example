# Environment Configuration
NODE_ENV=production

# Server Configuration
PORT=5000

# Database Configuration
# For local development: mongodb://127.0.0.1:27017/expenseflow
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/expenseflow?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/expenseflow

# JWT Configuration
# Generate a strong secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-secret-min-32-characters
JWT_EXPIRES_IN=7d

# CORS Configuration
# For development: http://127.0.0.1:5500
# For production: https://your-frontend-domain.com
# Multiple origins can be separated by commas: https://domain1.com,https://domain2.com
CORS_ORIGIN=http://127.0.0.1:5500
